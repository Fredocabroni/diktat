# Diktat — environment template. Copy to .env.local and fill in real values.

# --- Supabase ---
SUPABASE_URL_DEV=
SUPABASE_ANON_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_DEV=
SUPABASE_PROJECT_REF_DEV=
SUPABASE_URL_PROD=
SUPABASE_ANON_KEY_PROD=
SUPABASE_SERVICE_ROLE_KEY_PROD=
SUPABASE_PROJECT_REF_PROD=

# --- Redis (Upstash) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Direct Postgres connection used by the workers LISTEN/NOTIFY client.
# Read from Supabase → Project Settings → Database → Connection string (URI).
DATABASE_URL=

# --- Privy (custodial wallets) ---
# Workers listener provisions Solana custodial wallets when this flag is on
# AND both keys are non-empty. Until keys land, the listener logs a skip.
PRIVY_ENABLED=false
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# --- Observability ---
AXIOM_TOKEN=
AXIOM_DATASET=

# --- LiveKit ---
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# --- AI providers ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=

# --- Deploy targets ---
# TODO(vercel): VERCEL_TOKEN once Vercel account exists
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
# TODO(railway): RAILWAY_TOKEN
RAILWAY_TOKEN=

# --- API runtime ---
# Number of trusted reverse-proxy hops in front of the API (Railway edge = 1,
# +1 per CDN like Cloudflare). MUST be set in production: server.ts asserts
# at boot and refuses to start if NODE_ENV=production but this is unset,
# because every IP-keyed rate-limit counter would otherwise collapse to the
# proxy IP and bypass the public-tier budgets. Confirm empirically: set it,
# curl /health, check the boot log's request.ip resolves to the real client
# IP, not the proxy. UNSET in local dev (no proxy).
TRUSTED_PROXY_HOPS=

# --- X / Twitter ---
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
