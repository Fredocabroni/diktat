{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".turbo", "**/__tests__/**", "**/*.test.ts"],
  "references": [
    { "path": "../db/tsconfig.build.json" },
    { "path": "../shared/tsconfig.build.json" }
  ]
}
