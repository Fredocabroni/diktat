{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7",
  "effortLevel": "high",
  "permissions": {
    "deny": [
      "Bash(sed -i:*)",
      "Bash(*<<*EOF*)",
      "Bash(git push * main*)",
      "Bash(git push origin main*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf /:*)"
    ],
    "allow": [
      "Bash(pnpm:*)",
      "Bash(turbo:*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout -b*)",
      "Bash(git add *)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(supabase status*)",
      "Bash(supabase db lint*)",
      "Bash(node --version)",
      "Bash(pnpm --version)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-tool-use.sh" }]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/pre-tool-use.sh" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{ "type": "command", "command": ".claude/hooks/post-edit.sh" }]
      }
    ],
    "PreCompact": [
      { "hooks": [{ "type": "command", "command": ".claude/hooks/pre-compact.sh" }] }
    ],
    "SessionStart": [
      { "hooks": [{ "type": "command", "command": ".claude/hooks/session-start.sh" }] }
    ]
  }
}
