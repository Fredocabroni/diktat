    "@supabase/supabase-js": "^2.47.10",
    "@upstash/redis": "^1.34.3",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
