{
  "name": "@diktat/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "exports": {
    "./router": {
      "types": "./src/routers/index.ts",
      "default": "./src/routers/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@diktat/auth": "workspace:*",
    "@diktat/db": "workspace:*",
    "@diktat/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@supabase/supabase-js": "^2.47.10",
    "@trpc/server": "^11.0.0-rc.682",
    "fastify": "^5.2.1",
    "superjson": "^2.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
