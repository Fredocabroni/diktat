{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".turbo", "**/__tests__/**", "**/*.test.ts"],
  "references": [
    { "path": "../../packages/db/tsconfig.build.json" },
    { "path": "../../packages/shared/tsconfig.build.json" },
    { "path": "../../packages/auth/tsconfig.build.json" }
  ]
}
